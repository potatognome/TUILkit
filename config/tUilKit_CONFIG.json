        "ROOT_MODES: project"    : "Paths are relative to the project root.",
        "ROOT_MODES: workspace"  : "Paths are relative to the workspace root.",
        "CONFIG"                 : "workspace",
        "LOGS"                   : "workspace",
        "INPUTS"                 : "workspace",
        "OUTPUTS"                : "workspace",
        "TEST_CONFIG"            : "workspace",
        "TEST_LOGS"              : "workspace",
        "TEST_INPUTS"            : "workspace",
        "TEST_OUTPUTS"           : "workspace"
    },
    "PATHS": {
        "CONFIG": "config/",
        "LOGS"  : ".logs/tUilKit/",
        "INPUTS": ".projects_data/inputs/",
